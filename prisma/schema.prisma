// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id              String      @id @default(cuid())
  name            String
  category        String
  description     String
  image           String
  images          String[]
  sizes           String[]
  color           String
  // Artikelspezifische Limits: 1 = max 1x pro Jahr, 4 = max 4x pro Jahr (default)
  yearlyLimit     Int         @default(4)
  // Lagerbestand pro Größe (JSON: {"S": 10, "M": 5, ...})
  stock           Json?
  // Größentabelle URL oder Inhalt
  sizeChart       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]
  favorites       Favorite[]
  reviews         Review[]
}

model Employee {
  id                  String    @id @default(cuid())
  employeeId          String    @unique // Personalnummer
  email               String    @unique
  firstName           String
  lastName            String
  department          String
  password            String
  isActive            Boolean   @default(true)
  quotaResetDate      DateTime? // Datum ab dem das Jahreskontingent zählt
  // Password Reset
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  // Sprache
  language            String    @default("de")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  orders              Order[]
  favorites           Favorite[]
  feedbacks           Feedback[]
  reviews             Review[]
}

model Order {
  id           String      @id @default(cuid())
  customerName String
  email        String
  street       String
  city         String
  zip          String
  department   String
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]
  employeeId   String?
  employee     Employee?   @relation(fields: [employeeId], references: [id])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  size      String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model SupplierUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model CompanyArea {
  id          String   @id @default(cuid())
  name        String   @unique
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  // Kostenstellen-Zuordnung
  costCenter  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Settings {
  id        String   @id @default("settings")
  
  // Email Settings
  smtpHost     String   @default("")
  smtpPort     Int      @default(587)
  smtpUser     String   @default("")
  smtpPassword String   @default("")
  smtpSecure   Boolean  @default(true)
  emailFrom    String   @default("")
  emailFromName String  @default("RealCore Shop")
  
  // Notification Settings
  notifyOnOrder     Boolean @default(true)
  notifyOnShipment  Boolean @default(true)
  adminEmail        String  @default("")
  
  // Shop Settings
  shopName          String  @default("RealCore Mitarbeiter-Shop")
  maxItemsPerOrder  Int     @default(4)
  
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
}

// Favoriten / Merkliste
model Favorite {
  id         String   @id @default(cuid())
  employeeId String
  productId  String
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, productId])
}

// Feedback-Modul
model Feedback {
  id         String   @id @default(cuid())
  employeeId String
  orderId    String?
  message    String
  rating     Int?     // 1-5 Sterne optional
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// Bewertungen der Artikel
model Review {
  id         String   @id @default(cuid())
  employeeId String
  productId  String
  rating     Int      // 1-5 Sterne
  comment    String?
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, productId])
}
